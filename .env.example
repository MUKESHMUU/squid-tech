# Firebase Configuration Template
# NEVER commit actual keys to version control!
# Copy this file to .env and fill in your Firebase project values.

# Obtain these from Firebase Console > Project Settings > SDK Setup

NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# Optional: Sentry error tracking (v2)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/PROJECT_ID

# Optional: Analytics provider
# ANALYTICS_KEY=YOUR_ANALYTICS_KEY

# Application Settings
REACT_APP_LEADERBOARD_LIMIT=10
REACT_APP_SESSION_TTL_MS=1800000
REACT_APP_DEBOUNCE_MS=500
